# Copy this file to the server and adjust values before starting the backend.

# Runtime data directory. Keep it outside the source tree in production.
LLM_PLATFORM_RUNTIME_DIR=/opt/industrial-agent-system/runtime

# Comma-separated frontend or host application origins allowed to call backend APIs.
# Use "*" only for internal test environments.
AGENT_SYSTEM_CORS_ORIGINS=https://main-app.example.com,https://agent-system.example.com
AGENT_SYSTEM_CORS_SUPPORTS_CREDENTIALS=false

# Optional model runtime controls.
MODEL_RUNTIME_FORCE_CPU=false
MODEL_RUNTIME_MAX_NEW_TOKENS=512
MODEL_RUNTIME_TEMPERATURE=0.7
MODEL_RUNTIME_TOP_P=0.9

# Optional LLaMA-Factory controls.
LLAMAFACTORY_CLI=llamafactory-cli
LLAMAFACTORY_WORKDIR=/opt/industrial-agent-system
